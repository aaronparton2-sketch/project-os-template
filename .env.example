# .env.example — placeholder variable names only
# Copy this file to .env and fill in real values. NEVER commit .env.
# See reference/integrations-catalog.md for usage context and setup notes.

# ── Anthropic / Claude ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── n8n MCP Server (Claude ↔ n8n via Model Context Protocol) ───────────────
N8N_MCP_SERVER_URL=
N8N_MCP_ACCESS_TOKEN=

# ── n8n REST API ───────────────────────────────────────────────────────────
N8N_API_URL=
N8N_API_KEY=

# ── Apify ──────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=
APIFY_USER_ID=

# ── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# MCP server uses a Personal Access Token (different from service role key)
# Get from: supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# ── Google (Sheets, Drive, etc.) ───────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=

# ── YouTube (OAuth 2.0 — Desktop App) ────────────────────────────────────
# Get from: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_PROJECT_ID=

# ── Instagram (Graph API — Meta App) ─────────────────────────────────────
# Get from: developers.facebook.com > Your App > Settings
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Upwork (OAuth 2.0 — pending API approval) ────────────────────────────
# Get from: upwork.com/developer after API key approval
UPWORK_API_KEY=
UPWORK_API_SECRET=

# ── Project-specific vars ──────────────────────────────────────────────────
# Add project-specific API keys, config, etc. below this line
