# .env.example — placeholder variable names only
# Copy this file to .env and fill in real values. NEVER commit .env.
# See reference/integrations-catalog.md for usage context and setup notes.

# ══════════════════════════════════════════════════════════════════════════════
# API INTEGRATIONS (direct API calls from scripts/code)
# ══════════════════════════════════════════════════════════════════════════════

# ── Anthropic / Claude ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── n8n REST API ───────────────────────────────────────────────────────────
N8N_API_URL=
N8N_API_KEY=

# ── Apify ──────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=
APIFY_USER_ID=

# ── Supabase (API access) ─────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Google (Sheets, Drive, etc.) ───────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=

# ── YouTube (OAuth 2.0 — Desktop App) ────────────────────────────────────
# Get from: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_PROJECT_ID=

# ── Instagram (Graph API — Meta App) ─────────────────────────────────────
# Get from: developers.facebook.com > Your App > Settings
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Stripe (REST API — Read-Only Restricted Key) ─────────────────────────
# Get from: Stripe Dashboard > Developers > API Keys > Create restricted key
# Grant ONLY: Charges Read, Customers Read, Invoices Read, Subscriptions Read
# Key starts with rk_live_ (restricted) — NEVER use sk_live_ (full secret)
STRIPE_SECRET_KEY=

# ── Upwork (OAuth 2.0 — pending API approval) ────────────────────────────
# Get from: upwork.com/developer after API key approval
UPWORK_API_KEY=
UPWORK_API_SECRET=

# ══════════════════════════════════════════════════════════════════════════════
# MCP SERVER INTEGRATIONS (Claude Code ↔ external tools via .mcp.json)
# ══════════════════════════════════════════════════════════════════════════════
#
# Every MCP server in .mcp.json uses ${ENV_VAR} references back to this file.
# If a var below is empty, that MCP server won't connect.
#
# SETUP CHECKLIST (per MCP server):
#   1. Fill in the env vars below
#   2. Run any one-time auth flows (noted per server)
#   3. Restart Claude Code to pick up changes
#   4. Test with /prime — integration status will show ✓/✗

# ── n8n MCP Server ────────────────────────────────────────────────────────
# Exposes n8n workflows as tools Claude can call directly
# Auth: Bearer JWT from n8n MCP server node
N8N_MCP_SERVER_URL=
N8N_MCP_ACCESS_TOKEN=

# ── Supabase MCP Server ──────────────────────────────────────────────────
# Gives Claude direct DB access (queries, migrations, edge functions)
# Auth: Personal Access Token (NOT service role key)
# Get from: supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# ── Gmail MCP Server ─────────────────────────────────────────────────────
# Gives Claude email read/write/search access
# Auth: OAuth 2.0 Desktop App (credentials stored in config dir)
# Config dir contains: gcp-oauth.keys.json + auto-generated token
# ONE-TIME SETUP:
#   1. Save OAuth credentials JSON to the config dir as gcp-oauth.keys.json
#   2. Run: npx @gongrzhe/server-gmail-autoauth-mcp auth
#   3. Complete browser OAuth consent flow
GMAIL_MCP_CONFIG_DIR=~/.gmail-mcp

# ══════════════════════════════════════════════════════════════════════════════
# PROJECT-SPECIFIC VARS — Lead Generation Pipeline
# ══════════════════════════════════════════════════════════════════════════════

# ── ABR (Australian Business Register) ───────────────────────────────────
# Free API — register at abr.business.gov.au/Tools/WebServices
ABR_GUID=

# ── Instantly (Cold Email Warmup + Sending) ──────────────────────────────
# Get from: instantly.ai > Settings > API
INSTANTLY_API_KEY=

# ── Outreach Domains ──────────────────────────────────────────────────────
# Secondary domains for cold email (never use primary business domain)
OUTREACH_DOMAIN_1=
OUTREACH_DOMAIN_2=

# ── Zoho Mail (IMAP/SMTP for outreach domains) ───────────────────────────
# Used by n8n for reply monitoring via IMAP
ZOHO_IMAP_HOST=imappro.zoho.com.au
ZOHO_SMTP_HOST=smtppro.zoho.com.au

# ── Twilio (SMS Outreach) ────────────────────────────────────────────────
# Get from: console.twilio.com > Account Info + API Keys
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_PHONE_NUMBER=
